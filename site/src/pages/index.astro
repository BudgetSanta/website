---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Base title="BudgetSanta — Personal Blog">
  <section class="hero">
    <h1>Hi, I'm BudgetSanta 👋</h1>
    <p>
      I write about software, systems, and whatever else I find interesting.
      Technical posts, occasional essays, and notes to my future self.
    </p>
    <div class="hero-links">
      <a href={`${import.meta.env.BASE_URL}blog`} class="btn btn-primary">Read the Blog</a>
      <a href={`${import.meta.env.BASE_URL}about`} class="btn btn-secondary">About Me</a>
    </div>
  </section>

  {posts.length > 0 && (
    <section>
      <p class="section-heading">Recent Posts</p>
      <ul class="post-list">
        {posts.slice(0, 5).map((post) => (
          <li class="post-list-item">
            <h2>
              <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`}>{post.data.title}</a>
            </h2>
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            </div>
            {post.data.description && (
              <p class="post-description">{post.data.description}</p>
            )}
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
