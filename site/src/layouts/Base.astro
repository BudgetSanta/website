---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal technical blog by Jared Steiner.' } = Astro.props;
const { pathname } = Astro.url;

function isActive(href: string) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={`${import.meta.env.BASE_URL}`} class="site-title">Jared Steiner</a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href={`${import.meta.env.BASE_URL}blog`} aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a>
          <a href={`${import.meta.env.BASE_URL}about`} aria-current={isActive('/about') ? 'page' : undefined}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Jared Steiner &mdash; Built with <a href="https://astro.build">Astro</a></p>
      </div>
    </footer>
  </body>
</html>
